# ─────────────────────────────────────────────────────────────────────────────
# GlioblastomaGPT — Environment Variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM ──────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small   # fallback if BGE-M3 unavailable

# ── BGE-M3 Embeddings ─────────────────────────────────────────────────────────
# Downloaded automatically via fastembed on first run (~2GB)
EMBEDDING_MODEL=BAAI/bge-m3

# ── Retrieval Mode ────────────────────────────────────────────────────────────
# "pinecone"  → Version A: Pinecone vector DB
# "numpy"     → Version B: in-memory NumPy hybrid (no external DB required)
RETRIEVAL_MODE=numpy

# ── Pinecone (Version A only) ─────────────────────────────────────────────────
PINECONE_API_KEY=pcsk_...
PINECONE_INDEX_NAME=gbm-copilot
PINECONE_ENVIRONMENT=us-east-1-aws

# ── LangSmith Tracing ─────────────────────────────────────────────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_PROJECT=gbm-copilot

# ── PubMed / NCBI E-utilities ─────────────────────────────────────────────────
# Any valid email address — required by NCBI terms of service
NCBI_EMAIL=your@email.com

# ── Ingest Settings ───────────────────────────────────────────────────────────
INGEST_QUICK_MODE=false          # true = 500 abstracts (dev/testing)
CHUNK_SIZE_TOKENS=256
CHUNK_OVERLAP_PCT=0.20
MAX_PUBMED_RESULTS=50000

# ── Safety & Confidence ───────────────────────────────────────────────────────
MIN_CONFIDENCE_THRESHOLD=0.50    # Below this → answer blocked
FAITHFULNESS_WARNING_THRESHOLD=0.70  # Below this → "limited evidence" flag

# ── API ───────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=["http://localhost:8501","http://localhost:3000"]

# ── MCP Server ────────────────────────────────────────────────────────────────
MCP_PORT=8001
